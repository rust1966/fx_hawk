# UI
# -----------------------------
st.markdown('<div class="app-shell">', unsafe_allow_html=True)

logo_path = Path(__file__).with_name("fx_hawk_logo.png")
brand_cols = st.columns([1, 3.6])
with brand_cols[0]:
