    <table class="hawk-table">
        <tr>
            <th>Rating</th>
            <th>Rate Range</th>
        </tr>
        <tr>
            <td>Excellent</td>
            <td>{rate4(excellent_rng[0])} – {rate4(excellent_rng[1])}</td>
        </tr>
        <tr>
            <td>Fair</td>
            <td>{rate4(fair_rng[0])} – {rate4(fair_rng[1])}</td>
        </tr>
        <tr>
            <td>Expensive</td>
            <td>{rate4(expensive_rng[0])} – {rate4(expensive_rng[1])}</td>
        </tr>
